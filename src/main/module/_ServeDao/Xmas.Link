sql update::_sql::UPDATE table SET key = '@key@' WHERE id = '@id@'::{"":"※ 参数: <br>用于更新(增加/删除/更新)的SQL语句<br><br>SQL例子: <br>&emsp;&emsp;INSERT INTO table (test_id, test_value) VALUES ('@test_id@', '@test_value@')<br>&emsp;&emsp;INSERT INTO table (test_id, test_value) VALUES ('@list>>0>>test_id@', '@list>>0>>test_value@'),('@list>>1>>test_id@', '@list>>1>>test_value@')<br>&emsp;&emsp;DELETE FROM table WHERE test_id = '@test_id@'<br>&emsp;&emsp;UPDATE table SET test_value = '@test_value@' WHERE id = '@test_id@'","en":"※ Param: <br>SQL statements for updating(insert/delete/update)<br><br>SQL samples: <br>&emsp;&emsp;INSERT INTO table (test_id, test_value) VALUES ('@test_id@', '@test_value@')<br>&emsp;&emsp;INSERT INTO table (test_id, test_value) VALUES ('@list>>0>>test_id@', '@list>>0>>test_value@'),('@list>>1>>test_id@', '@list>>1>>test_value@')<br>&emsp;&emsp;DELETE FROM table WHERE test_id = '@test_id@'<br>&emsp;&emsp;UPDATE table SET test_value = '@test_value@' WHERE id = '@test_id@'"}
